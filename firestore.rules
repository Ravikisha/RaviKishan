rules_version = '2';

// Firestore security rules for the portfolio.
// Deploy these in Firebase console → Firestore Database → Rules → Publish.
// They are what actually protect the admin CMS: the hidden /admin URL is only
// obscurity; THIS is the lock.
service cloud.firestore {
  match /databases/{database}/documents {

    // Editable site content shown across the public site.
    // World-readable (the site fetches it); writable ONLY by the specific
    // authorized admin account(s), with a verified email. Signing in (even with
    // Google) is not enough — the email must match the allow-list. Keep this
    // list in sync with lib/adminAllowlist.js.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['ravikishan63392@gmail.com'];
    }
    match /site/content {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public contact-form submissions (components/contactForm.js -> addDoc).
    // Anyone may submit; only the admin may read or delete (admin Inbox).
    match /myportifilio/{docId} {
      allow create: if true;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // Direct messages from the Mail app (components/os/apps/Mail.js).
    // Anyone may send a well-formed message; only the admin may read or delete.
    match /mail/{docId} {
      allow create: if request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 120
        && request.resource.data.email is string
        && request.resource.data.email.size() >= 3
        && request.resource.data.email.size() <= 200
        && request.resource.data.subject is string
        && request.resource.data.subject.size() >= 1
        && request.resource.data.subject.size() <= 200
        && request.resource.data.message is string
        && request.resource.data.message.size() >= 1
        && request.resource.data.message.size() <= 5000;
      allow read, delete: if isAdmin();
      allow update: if false;
    }

    // Public chat room / lobby (components/os/apps/Chat.js).
    // World-readable; anyone may post a well-formed message; only the admin may
    // delete (moderation from the Inbox). No client edits.
    match /chat/{docId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
        && request.resource.data.text.size() >= 1
        && request.resource.data.text.size() <= 500
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 24;
      allow delete: if isAdmin();
      allow update: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
