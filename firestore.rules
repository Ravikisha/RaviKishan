rules_version = '2';

// Firestore security rules for the portfolio.
// Deploy these in Firebase console → Firestore Database → Rules → Publish.
// They are what actually protect the admin CMS: the hidden /admin URL is only
// obscurity; THIS is the lock.
service cloud.firestore {
  match /databases/{database}/documents {

    // Editable site content shown across the public site.
    // World-readable (the site fetches it); writable ONLY by the specific
    // authorized admin account(s), with a verified email. Signing in (even with
    // Google) is not enough — the email must match the allow-list. Keep this
    // list in sync with lib/adminAllowlist.js.
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in ['ravikishan63392@gmail.com'];
    }
    match /site/content {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public contact-form submissions (components/contactForm.js -> addDoc).
    // Anyone may submit; nobody may read/modify/delete from the client.
    match /myportifilio/{docId} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
