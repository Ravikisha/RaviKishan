# Instagram feed for the Gallery app (@ravikishan.404).
# Copy this file to `.env.local` and fill in a real token, then restart `next dev`.
# `.env.local` is git-ignored by Next — the token never gets committed.

# Required — long-lived Instagram access token (see setup steps below / README).
IG_ACCESS_TOKEN=

# Optional — your Instagram user id. Leave blank to use "me" (the token's owner).
IG_USER_ID=
